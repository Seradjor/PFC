<odoo>
  <data>

    <!-- Lista fichajes -->
    <record model="ir.ui.view" id="time_tracking_list">
        <field name="name">Registro fichajes</field>
        <field name="model">time_tracking.record</field>
        <field name="arch" type="xml">
            <tree string="Registro fichajes" create="false" editable="top" default_order="date desc"
                decoration-success="type == 'entry'" decoration-primary="type == 'exit'">

                <field name="employee_id" readonly="1"/>
                <field name="date" readonly="1"/>
                <field name="time" widget="float_time"/>
                <field name="type"/>
                <field name="duration" readonly="1"/>

            </tree>
        </field>
    </record>

    <!-- Lista resultado de consulta fichajes -->
    <record model="ir.ui.view" id="time_tracking_records_list">
        <field name="name">Fichajes empleado</field>
        <field name="model">time_tracking.record</field>
        <field name="arch" type="xml">
            <tree string="Fichajes empleado" create="false" editable="top" multi_edit="1"
                default_order="date desc" decoration-success="type == 'entry'" decoration-primary="type == 'exit'">

                <header>

                    <button name="action_export_pdf" type="object" string="Informe PDF" class="btn-primary" display="always"/>
                    <button name="action_export_csv" type="object" string="Informe CSV" class="btn-primary" display="always"/>
                    <button name="action_send_email" type="object" string="Enviar email" class="btn-primary" display="always"/>

                </header>

                <field name="date" readonly="1"/>
                <field name="time" widget="float_time"/>
                <field name="type"/>
                <field name="duration" readonly="1"/>

            </tree>
        </field>
    </record>


    <!-- Form consulta fichajes -->
    <record model="ir.ui.view" id="time_tracking.search_records_view">
        <field name="name">Consulta fichajes</field>
        <field name="model">time_tracking.records_search</field>
        <field name="arch" type="xml">
            <form string="Fichajes empleado" create="false">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date_start" string="Día inicial"/>
                        <field name="date_end" string="Día final"/>
                    </group>

                    <footer>
                        <button string="Aceptar" type="object" name="action_search_records" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>


    <!-- Form registro nuevo fichaje -->
    <record model="ir.ui.view" id="time_tracking.manual_tracking">
        <field name="name">Registro fichaje manual</field>
        <field name="model">time_tracking.record</field>
        <field name="arch" type="xml">
            <form string="Registro fichaje manual" create="false">
                <sheet>
                <group>
                    <field name="employee_id"/>
                    <field name="date"/>
                    <field name="time" widget="float_time"/>
                    <field name="type"/>
                </group>

                <footer>
                    <button string="Aceptar" type="object" name="action_save_day" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </sheet>
            </form>
        </field>
    </record>

    <!-- Vista form predeterminada -->
    <record model="ir.ui.view" id="time_tracking.form">
        <field name="name">Fichajes empleados</field>
        <field name="model">time_tracking.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="record_id" readonly="1"/>
                        <field name="date"/>
                        <field name="time" widget="float_time"/>
                        <field name="type"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Ver lista fichajes, ventana principal -->
    <record model="ir.actions.act_window" id="time_tracking.action_window_records">
        <field name="name">Registros de fichaje</field>
        <field name="res_model">time_tracking.record</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="time_tracking.time_tracking_list"/>
        <field name="context">{'group_by': 'employee_id'}</field>
    </record>


    <!-- Exportar consulta fichajes a PDF -->
    <record model="ir.actions.report" id="time_tracking.action_report_time_tracking">
        <field name="name">Informe de fichajes</field>
        <field name="model">time_tracking.record</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">time_tracking.report_template_pdf</field>
    </record>


    <!-- Consulta fichajes -->
    <record model="ir.actions.act_window" id="time_tracking.action_search_records">
        <field name="name">Consulta fichajes</field>
        <field name="res_model">time_tracking.records_search</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="time_tracking.search_records_view"/>
        <field name="target">new</field>
    </record>
    
    <!-- Registro manual nuevo fichaje -->
    <record model="ir.actions.act_window" id="time_tracking.action_manual_tracking">
        <field name="name">Registro manual</field>
        <field name="res_model">time_tracking.record</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="time_tracking.manual_tracking"/>
        <field name="target">new</field>
    </record>


    <!-- Menú principal-->
    <menuitem name="Fichajes" id="time_tracking.menu_root" action="time_tracking.action_window_records"/>

    <menuitem name="Inicio" id="time_tracking.menu_home" parent="time_tracking.menu_root"/>

    <!-- Pestañas dentro de menú "Inicio" -->
    <menuitem name="Nuevo fichaje" id="time_tracking.menu_manual" parent="time_tracking.menu_home"
              action="time_tracking.action_manual_tracking" sequence="1"/>

    <menuitem name="Consulta fichajes" id="time_tracking.records_search" parent="time_tracking.menu_home"
              action="time_tracking.action_search_records" sequence="2"/>

  </data>
</odoo>