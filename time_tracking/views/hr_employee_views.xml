<odoo>
    <data>

        <record model="ir.ui.view" id="view_employee_form_inherit_time_tracking">
            <field name="name">Pestaña fichajes</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">

                <!-- Insertamos una nueva pestaña al final del notebook -->
                <xpath expr="//notebook" position="inside">
                    <page string="Fichajes">
                        <div class="oe_button_box" style="display:flex; gap:15px; align-items:center; margin-bottom: 10px">
                            <span style="margin-right: 20px">ID fichaje: <field name="id_time_tracking" readonly="id != False"/></span>

                            <button name="action_generate_new_id"
                                type="object"
                                string="Generar nuevo ID"
                                class="btn-primary"/>

                            <button name="action_write_card"
                                type="object"
                                string="Grabar tarjeta"
                                class="btn-primary"/>
                        </div>

                        <group>
                            <field name="records_ids" mode="tree" nolabel="4">
                                <tree string="Fichajes" create="false" edit="false" delete="false" default_order="date desc, time asc"
                                    decoration-success="type == 'entry'" decoration-primary="type == 'exit'">
                                    <field name="date"/>
                                    <field name="time" widget="float_time"/>
                                    <field name="type"/>
                                    <field name="duration"/>
                                </tree>
                            </field>
                        </group>
                    </page>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
