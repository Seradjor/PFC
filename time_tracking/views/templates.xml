<odoo>
    <data>

        <template id="report_template_pdf">
            <t t-call="web.html_container">

                <meta charset="UTF-8"/>

                <style>
                    .container {
                        max-width: 900px;
                        margin: auto;
                        font-size: 14px;
                    }

                    table {
                        width: 100%;
                        border-collapse: collapse;
                        margin-top: 20px;
                    }

                    th, td {
                        border: 1px solid #ccc;
                        padding: 8px;
                    }

                    th {
                        background-color: #f0f0f0;
                    }

                    h1, h2, h3 {
                        margin-bottom: 10px;
                    }
                </style>

                <div class="container">

                    <h1>Informe de fichajes</h1>

                    <h2>
                        Empleado:
                        <t t-esc="employee_name"/>
                    </h2>

                    <p>
                        Desde <strong><t t-esc="date_start"/></strong>
                        hasta <strong><t t-esc="date_end"/></strong>
                    </p>

                    <!-- Tabla principal -->
                    <table>
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Detalle</th>
                                <th>Horas</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-foreach="lines" t-as="line">
                                <tr>
                                    <td><t t-esc="line['date']"/></td>
                                    <td><t t-esc="line['detail']"/></td>
                                    <td><t t-esc="line['hours']"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Resumen -->
                    <h3>Resumen</h3>

                    <table>
                        <tbody>
                            <tr>
                                <td>Total horas realizadas</td>
                                <td><t t-esc="total_worked_hours"/></td>
                            </tr>
                            <tr>
                                <td>Horas esperadas</td>
                                <td><t t-esc="expected_hours"/></td>
                            </tr>
                            <tr>
                                <td>Diferencia</td>
                                <td><t t-esc="hours_difference"/></td>
                            </tr>
                            <tr>
                                <td>Horas extra</td>
                                <td><t t-esc="extra_hours"/></td>
                            </tr>
                            <tr>
                                <td>Horas festivo</td>
                                <td><t t-esc="holiday_hours"/></td>
                            </tr>
                            <tr>
                                <td>Equivalencia horas extra/festivo</td>
                                <td><t t-esc="extra_holiday_value"/></td>
                            </tr>
                        </tbody>
                    </table>

                </div>

            </t>
        </template>

        <template id="email_report_template">
            <div>

                <h2>Informe de fichajes</h2>

                <p>Empleado: <t t-esc="doc['employee_name']"/></p>

                <p>Semana: <t t-esc="doc['date_start']"/> - <t t-esc="doc['date_end']"/></p>

                <table border="1" style="border-collapse: collapse; width: auto; gap: 10px">
                    <thead>
                        <tr>
                            <th style="font-size: 14px; padding: 6px 10px;">Fecha</th>
                            <th style="font-size: 14px; padding: 6px 10px;">Detalle</th>
                            <th style="font-size: 14px; padding: 6px 10px;">Horas</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-foreach="doc['lines']" t-as="line">
                            <tr>
                                <td style="padding: 6px 10px;"><t t-esc="line['date']"/></td>
                                <td style="padding: 6px 10px;"><t t-esc="line['detail']"/></td>
                                <td style="padding: 6px 10px;"><t t-esc="line['hours']"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <h3>Resumen</h3>

                <table border="1" style="border-collapse: collapse; width: auto;">
                    <tbody>
                        <tr>
                            <td style="padding: 6px 10px;">Total horas realizadas:</td>
                            <td style="padding: 6px 10px;"><t t-esc="doc['total_worked_hours']"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 10px;">Horas esperadas:</td>
                            <td style="padding: 6px 10px;"><t t-esc="doc['expected_hours']"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 10px;">Diferencia:</td>
                            <td style="padding: 6px 10px;"><t t-esc="doc['hours_difference']"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 10px;">Horas extra:</td>
                            <td style="padding: 6px 10px;"><t t-esc="doc['extra_hours']"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 10px;">Horas festivo:</td>
                            <td style="padding: 6px 10px;"><t t-esc="doc['holiday_hours']"/></td>
                        </tr>
                        <tr>
                            <td style="padding: 6px 10px;">Equivalencia horas extra/festivo:</td>
                            <td style="padding: 6px 10px;"><t t-esc="doc['extra_holiday_value']"/></td>
                        </tr>
                    </tbody>
                </table>

            </div>
        </template>


        <template id="email_report_template_no_records">
            <div>
                <h2>Informe de fichajes</h2>

                <p>Empleado: <t t-esc="doc['employee_name']"/></p>

                <p>Semana: <t t-esc="doc['date_start']"/> - <t t-esc="doc['date_end']"/></p>

                <p>No se han realizado fichajes en el período señalado.</p>
            </div>
        </template>


        <template id="email_report_template_no_email_info">
            <div>
                <h2>Informe de fichajes</h2>

                <p>No se ha podido enviar el informe semanal a
                    <t t-esc="doc['employee_name']"/>
                    debido a un problema con la dirección electrónica registrada.</p>
            </div>
        </template>

    </data>
</odoo>