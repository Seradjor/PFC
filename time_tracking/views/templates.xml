<odoo>
    <data>

        <template id="report_template_pdf">

            <t t-call="web.html_container">

                <meta charset="UTF-8"/>

                <style>

                    .container {
                        max-width: 900px;
                        margin: auto;
                        font-size: 14px;
                    }

                    /* --- TABLAS DEL INFORME --- */
                    .tabla_fichajes,
                    .tabla_resumen {
                        width: 100%;
                        border-collapse: collapse;
                        margin-top: 20px;
                    }

                    .tabla_fichajes th,
                    .tabla_fichajes td,
                    .tabla_resumen td {
                        border: 1px solid #ccc;
                        padding: 8px;
                    }

                    .tabla_fichajes th {
                        background-color: #f0f0f0;
                    }

                </style>

                <div class="container">

                    <h1>Informe de fichajes</h1>

                    <h2>
                        Empleado:
                        <t t-out="employee_name"/>
                    </h2>

                    <p>
                        Desde <strong><t t-out="date_start"/></strong>
                        hasta <strong><t t-out="date_end"/></strong>
                    </p>

                    <table class="tabla_fichajes">

                        <tr style="font-size: 20;">
                            <th>Fecha</th>
                            <th>Detalle</th>
                            <th>Horas</th>
                        </tr>

                        <t t-foreach="lines" t-as="line">
                            <tr>
                                <td><t t-out="line['date']"/></td>
                                <td><t t-out="line['detail']"/></td>
                                <td><t t-out="line['hours']"/></td>
                            </tr>
                        </t>

                    </table>

                    <h3>Resumen</h3>

                    <table class="tabla_resumen">

                        <tr>
                            <td>Total horas</td>
                            <td><t t-out="total_worked_hours"/></td>
                        </tr>

                        <tr>
                            <td>Esperadas</td>
                            <td><t t-out="expected_hours"/></td>
                        </tr>

                        <tr>
                            <td>Diferencia</td>
                            <td><t t-out="hours_difference"/></td>
                        </tr>

                        <tr>
                            <td>Extra</td>
                            <td><t t-out="extra_hours"/></td>
                        </tr>

                        <tr>
                            <td>Festivo</td>
                            <td><t t-out="holiday_hours"/></td>
                        </tr>

                        <tr>
                            <td>Valor</td>
                            <td><t t-out="extra_holiday_value"/></td>
                        </tr>

                    </table>

                </div>

            </t>

        </template>

        <template id="email_report_template">
            <div>
                <h2>Informe de fichajes</h2>

                <p>
                    Empleado: <t t-out="doc['employee_name']"/>
                </p>

                <p>
                    Semana: <t t-out="doc['date_start']"/> - <t t-out="doc['date_end']"/>
                </p>

                <table border="1">
                    <t t-foreach="doc['lines']" t-as="line">
                        <tr>
                            <td><t t-out="line['date']"/></td>
                            <td><t t-out="line['detail']"/></td>
                            <td><t t-out="line['hours']"/></td>
                        </tr>
                    </t>
                </table>

                <h3>Resumen</h3>

                <table border="1">
                    <tr><td>Total horas realizadas:</td><td><t t-out="doc['total_worked_hours']"/></td></tr>
                    <tr><td>Horas esperadas:</td><td><t t-out="doc['expected_hours']"/></td></tr>
                    <tr><td>Diferencia:</td><td><t t-out="doc['hours_difference']"/></td></tr>
                    <tr><td>Horas extra:</td><td><t t-out="doc['extra_hours']"/></td></tr>
                    <tr><td>Horas festivo:</td><td><t t-out="doc['holiday_hours']"/></td></tr>
                    <tr><td>Valor horas extra/festivo:</td><td><t t-out="doc['extra_holiday_value']"/></td></tr>
                </table>
            </div>
        </template>

        <template id="email_report_template_no_records">
            <div>
                <h2>Informe de fichajes</h2>

                <p>
                    Empleado: <t t-out="doc['employee_name']"/>
                </p>

                <p>
                    Semana: <t t-out="doc['date_start']"/> - <t t-out="doc['date_end']"/>
                </p>

                <p>
                    No se han realizado fichajes en el período señalado.
                </p>

            </div>
        </template>


        <template id="email_report_template_no_email_info">
            <div>
                <h2>Informe de fichajes</h2>

                <p>
                    No se ha podido enviar el informe semanal a <t t-out="doc['employee_name']"/> debido a un problema 
                    con la dirección electrónica registrada en el sistema.
                </p>

            </div>
        </template>

    </data>
</odoo>