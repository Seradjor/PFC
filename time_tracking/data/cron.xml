<odoo>
    <data>

        <record model="ir.cron" id="time_tracking_email_reports">
            <field name="name">Envio correo semanal fichajes</field>
            <field name="model_id" ref="model_time_tracking_report_service"/>
            <field name="state">code</field>
            <field name="code">model.send_weekly_reports()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="doall">False</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=22, minute=0) + relativedelta(weekday=6)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <!-- <field name="nextcall" eval="(DateTime.now() + relativedelta(minutes=1)).strftime('%Y-%m-%d %H:%M:%S')"/> -->
        </record>

    </data>
</odoo>